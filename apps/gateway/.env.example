PORT=3000

# Neon DB — get these from https://neon.tech dashboard
# Use the "pooled" connection string for DATABASE_URL
# Use the "direct" connection string for DIRECT_URL (needed for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Redis — required for job queue (run locally: docker run -p 6379:6379 redis)
REDIS_URL="redis://localhost:6379"

# JWT — change to a long random string in production
JWT_SECRET="cffdf3b9ca1968c3481b3bd5bb52578aee27ba5a8d15aaed48f43db6e0edf0ab"

# Local file storage for PDFs (relative to project root or absolute)
UPLOAD_DIR="../../uploads"

# CORS origin (set to your frontend URL in production)
CORS_ORIGIN="http://localhost:5173"
